# ─────────────────────────────────────────────────────────────────────────────
# Qulture PRODUCTION env (Docker on a VPS). Copy to `.env` on the server and
# fill in real values. NEVER commit the real .env. Generate strong secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain / TLS (Caddy) ─────────────────────────────────────────────────────
DOMAIN="qulture.yourdomain.com"
ACME_EMAIL="you@yourdomain.com"

# ── Postgres (the bundled pgvector container) ────────────────────────────────
POSTGRES_USER="qulture"
POSTGRES_PASSWORD="CHANGE_ME_strong_password"
POSTGRES_DB="qulture"
# DATABASE_URL points at the compose `postgres` service. If you use EXTERNAL
# managed Postgres (Neon/Supabase/RDS — must have the `vector` extension),
# replace this with that URL and remove the postgres service from compose.
DATABASE_URL="postgresql://qulture:CHANGE_ME_strong_password@postgres:5432/qulture?schema=public"

# ── Redis (the bundled redis container, or external e.g. Upstash) ────────────
REDIS_URL="redis://redis:6379"

# ── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_generate_32_byte_secret"
NEXTAUTH_URL="https://qulture.yourdomain.com"
# Optional OAuth — register callback https://<DOMAIN>/api/auth/callback/<provider>
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# ── Data + LLM providers ─────────────────────────────────────────────────────
# mock = seeded demo data · api/ingestion = real feeds (implement the stubs)
DATA_PROVIDER="mock"
NEXT_PUBLIC_DATA_PROVIDER="mock"
# Show the demo credentials hint on the login page. Leave unset/false in prod.
NEXT_PUBLIC_DEMO_MODE="false"
# anthropic uses the real model (recommended in prod); needs ANTHROPIC_API_KEY.
LLM_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# ── Real data ingestion ──────────────────────────────────────────────────────
# YouTube Data API v3 key (Google Cloud Console → enable "YouTube Data API v3"
# → create API key). Required for the /ingest admin tool + worker to pull real
# YouTube creators. Leave blank to keep mock-only.
YOUTUBE_API_KEY=""

# Instagram/TikTok have no free discovery API → ingested via a licensed data
# aggregator. Pick a vendor, subscribe, and set its key. Default adapter: Modash
# (offers keyword discovery + real audience demographics + fake-follower rate).
AGGREGATOR_VENDOR="modash"
AGGREGATOR_API_KEY=""

# ── Seed-on-deploy ───────────────────────────────────────────────────────────
# true = run the demo seed once during the migrate step (good for a hosted demo).
# Set to false / empty for a real launch (then ingest real data instead).
SEED_ON_DEPLOY="true"

# ── Webhook secrets (Tracking & ROI) — REQUIRED before exposing webhooks ─────
# Implement HMAC verification in src/lib/webhooks.ts before relying on these.
# SHOPIFY_WEBHOOK_SECRET=""
# STRIPE_WEBHOOK_SECRET=""
# GA4_API_SECRET=""
