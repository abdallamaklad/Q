# ─────────────────────────────────────────────────────────────────────────────
# Qulture environment configuration
# Copy this file to `.env` and fill in values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# Matches docker-compose.yml. The `vector` extension is enabled by setup.
DATABASE_URL="postgresql://qulture:qulture@localhost:5432/qulture?schema=public"

# ── Redis (cache + BullMQ queue) ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me-please-32-bytes-min"
NEXTAUTH_URL="http://localhost:3002"

# OAuth providers (optional — email/password works without these).
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# ── Data source abstraction ──────────────────────────────────────────────────
# Which DataProvider the app uses. The rest of the app is agnostic to this.
#   mock      → reads the seeded Postgres DB (default; fully functional offline)
#   api       → live platform APIs (stubs; requires keys below)
#   ingestion → BullMQ bulk ingestion pipeline (stubs; requires worker running)
DATA_PROVIDER="mock"
# Mirror of DATA_PROVIDER exposed to the client UI (display only).
NEXT_PUBLIC_DATA_PROVIDER="mock"

# ── LLM provider ─────────────────────────────────────────────────────────────
#   mock      → deterministic rule-based LLM (default; zero keys, fully offline)
#   anthropic → real Anthropic API (requires ANTHROPIC_API_KEY)
# If ANTHROPIC_API_KEY is set and LLM_PROVIDER is unset, anthropic is used.
LLM_PROVIDER="mock"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# ── Platform API keys (only needed when DATA_PROVIDER=api) ────────────────────
# YOUTUBE_API_KEY=""
# TIKTOK_CLIENT_KEY=""
# TIKTOK_CLIENT_SECRET=""
# INSTAGRAM_ACCESS_TOKEN=""
# X_BEARER_TOKEN=""
# TWITCH_CLIENT_ID=""
# TWITCH_CLIENT_SECRET=""

# ── Webhook receivers (Tracking & ROI; verify-signature stubs) ───────────────
# SHOPIFY_WEBHOOK_SECRET=""
# STRIPE_WEBHOOK_SECRET=""
# GA4_API_SECRET=""
